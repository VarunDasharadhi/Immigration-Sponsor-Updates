# Copy this file to .env.local and fill in your actual keys.
# DO NOT commit .env.local to version control.

# ── OpenRouter (required for live AI calls) ──────────────────────────────────
# Get a free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (default: google/gemini-2.5-flash)
# Data features use this model with :online suffix for web search.
# Simplify uses the base model (no web search needed).
# OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 10000)
PORT=10000
NODE_ENV=development

# ── Frontend API base URL ────────────────────────────────────────────────────
# Only needed in development if the Vite dev server (port 3000) talks to
# the API server on a different port. Leave unset when running from server.js.
# VITE_API_URL=http://localhost:10000
